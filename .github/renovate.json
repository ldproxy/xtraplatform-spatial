{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["ldproxy/renovate-config:xtraplatform", "ldproxy/renovate-config:maintenance2(7.7,7.6)"],
  "packageRules": [
    {
      "matchUpdateTypes": ["patch"],
      "matchCurrentVersion": "!/^0/",
      "automerge": true
    },
    {
      "matchUpdateTypes": ["digest"],
      "automerge": true
    },
    {
      "matchPackageNames": ["com.github.davidmoten:rxjava3-jdbc"],
      "allowedVersions": "!= 0.1.4"
    }
  ]
}
